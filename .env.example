# Discord Bot Configuration
# [REQUIRED] Your Discord Bot Token (https://discord.com/developers/applications)
BOT_TOKEN=your_token_here_do_not_share

# [OPTIONAL] Command prefixes, separated by commas if multiple
# Example: !, ?, bot!
BOT_PREFIXES=your_bot_prefixes

# API Keys
# [REQUIRED] External API Key for XYZ service
API_KEY=your_api_key_here